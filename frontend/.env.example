# El repo incluye `frontend/.env` con estos valores. Para overrides locales o producción,
# usa `.env.local` (ignorado por git) o copia este archivo.
#
# En producción el proxy /api-proxy apunta a BACKEND_URL solo en build.
# Si el front y el API están en dominios distintos, define la URL pública del API
# y configura CORS en el backend para el origen de tu web.
NEXT_PUBLIC_API_URL=

# URL interna del API para rewrites (dev: localhost; en servidor: URL interna del contenedor)
BACKEND_URL=http://localhost:5087
